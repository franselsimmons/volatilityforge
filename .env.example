# Base
SITE_URL=http://localhost:3000

# NOWPayments
NOWPAYMENTS_API_KEY=REPLACE_ME
NOWPAYMENTS_IPN_SECRET=REPLACE_ME

# Discord OAuth (Application)
DISCORD_CLIENT_ID=REPLACE_ME
DISCORD_CLIENT_SECRET=REPLACE_ME
DISCORD_REDIRECT_URI=http://localhost:3000/api/discord/oauth-callback

# Discord Bot (must be in your server and have Manage Roles)
DISCORD_BOT_TOKEN=REPLACE_ME
DISCORD_GUILD_ID=REPLACE_ME
DISCORD_INVITE_URL=https://discord.gg/REPLACE_ME

# Role IDs per plan
DISCORD_ROLE_BUILDUP=REPLACE_ME
DISCORD_ROLE_ALMOST=REPLACE_ME
DISCORD_ROLE_ENTRY=REPLACE_ME
DISCORD_ROLE_ALL=REPLACE_ME

# Optional: Vercel KV (only on Vercel; local can run without)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# KV_REST_API_READ_ONLY_TOKEN=